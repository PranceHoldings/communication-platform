{
  "name": "@prance/infrastructure",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "bash scripts/pre-deploy-clean.sh",
    "clean:spaces": "bash ../scripts/clean-space-directories.sh",
    "cdk": "echo '⚠️  WARNING: Use npm run deploy instead of direct cdk commands to ensure validation' && cdk",
    "bootstrap": "cdk bootstrap",
    "validate:bundling": "bash scripts/validate-cdk-bundling.sh",
    "predeploy": "npm run clean && npm run validate:bundling && node scripts/sync-env.js",
    "deploy": "bash scripts/cdk-wrapper.sh deploy --all",
    "deploy:lambda": "bash scripts/cdk-wrapper.sh deploy Prance-dev-ApiLambda --require-approval never",
    "build:nextjs": "bash ../scripts/build-nextjs-standalone.sh",
    "deploy:nextjs": "npm run build:nextjs && bash scripts/cdk-wrapper.sh deploy Prance-dev-NextJs --require-approval never",
    "deploy:dev": "./deploy.sh dev",
    "deploy:staging": "./deploy.sh staging",
    "deploy:production": "./deploy.sh production",
    "deploy:quick": "./deploy.sh",
    "deploy:dev-migration": "bash scripts/deploy-with-migration.sh dev",
    "deploy:production-migration": "bash scripts/deploy-with-migration.sh production",
    "destroy": "cdk destroy --all",
    "synth": "bash scripts/cdk-wrapper.sh synth",
    "diff": "bash scripts/cdk-wrapper.sh diff",
    "status": "aws cloudformation list-stacks --stack-status-filter CREATE_COMPLETE UPDATE_COMPLETE --query \"StackSummaries[?starts_with(StackName, 'Prance')].{Name:StackName,Status:StackStatus}\" --output table"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "aws-cdk": "^2.1109.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1005.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1005.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-lambda": "^3.1005.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/cloudfront-signer": "^3.1005.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.1005.0",
    "@prisma/client": "^5.9.0",
    "@react-pdf/renderer": "^4.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.18.0",
    "aws-cdk-lib": "^2.170.0",
    "bcryptjs": "^3.0.3",
    "constructs": "^10.3.0",
    "ffmpeg-static": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "redis": "^4.7.0",
    "ws": "^8.19.0"
  }
}
