{
  "name": "@prance/infrastructure",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "bootstrap": "cdk bootstrap",
    "predeploy": "node scripts/sync-env.js",
    "deploy": "cdk deploy --all",
    "deploy:dev": "./deploy.sh dev",
    "deploy:staging": "./deploy.sh staging",
    "deploy:production": "./deploy.sh production",
    "deploy:quick": "./deploy.sh",
    "destroy": "cdk destroy --all",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "status": "aws cloudformation list-stacks --stack-status-filter CREATE_COMPLETE UPDATE_COMPLETE --query \"StackSummaries[?starts_with(StackName, 'Prance')].{Name:StackName,Status:StackStatus}\" --output table"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "aws-cdk": "^2.1109.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@prisma/client": "^5.9.0",
    "@types/pg": "^8.18.0",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.3.0",
    "ffmpeg-static": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0"
  }
}
