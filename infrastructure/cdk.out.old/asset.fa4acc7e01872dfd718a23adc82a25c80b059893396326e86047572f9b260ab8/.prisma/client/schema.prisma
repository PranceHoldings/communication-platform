// Prance Communication Platform - Database Schema (Alpha版)
// Generator: Prisma Client

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 組織・ユーザー管理
// ============================================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  settings  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  avatars   Avatar[]
  scenarios Scenario[]
  sessions  Session[]

  @@map("organizations")
}

model User {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  email           String    @unique
  name            String
  role            UserRole  @default(CLIENT_USER)
  cognitoSub      String    @unique @map("cognito_sub")
  profileJson     Json?     @map("profile_json")
  preferencesJson Json?     @map("preferences_json")
  createdAt       DateTime  @default(now()) @map("created_at")
  lastLoginAt     DateTime? @map("last_login_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     Session[]
  avatars      Avatar[]

  @@index([orgId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  CLIENT_ADMIN
  CLIENT_USER
}

// ============================================================
// アバター・音声
// ============================================================

model Avatar {
  id           String       @id @default(uuid())
  userId       String?      @map("user_id")
  orgId        String       @map("org_id")
  name         String
  type         AvatarType
  style        AvatarStyle
  source       AvatarSource
  modelUrl     String       @map("model_url")
  thumbnailUrl String?      @map("thumbnail_url")
  configJson   Json?        @map("config_json")
  tags         String[]     @default([])
  visibility   Visibility   @default(PRIVATE)
  createdAt    DateTime     @default(now()) @map("created_at")

  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     Session[]

  @@index([orgId])
  @@index([userId])
  @@index([visibility])
  @@map("avatars")
}

enum AvatarType {
  TWO_D
  THREE_D
}

enum AvatarStyle {
  ANIME
  REALISTIC
}

enum AvatarSource {
  PRESET
  GENERATED
  ORG_CUSTOM
}

enum Visibility {
  PRIVATE
  ORGANIZATION
  PUBLIC
}

// ============================================================
// シナリオ
// ============================================================

model Scenario {
  id         String     @id @default(uuid())
  userId     String?    @map("user_id")
  orgId      String     @map("org_id")
  title      String
  category   String
  language   String     @default("ja")
  visibility Visibility @default(PRIVATE)
  configJson Json       @map("config_json")
  createdAt  DateTime   @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     Session[]

  @@index([orgId])
  @@index([category])
  @@map("scenarios")
}

// ============================================================
// セッション・録画
// ============================================================

model Session {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  orgId        String        @map("org_id")
  scenarioId   String        @map("scenario_id")
  avatarId     String        @map("avatar_id")
  status       SessionStatus @default(ACTIVE)
  startedAt    DateTime      @default(now()) @map("started_at")
  endedAt      DateTime?     @map("ended_at")
  durationSec  Int?          @map("duration_sec")
  metadataJson Json?         @map("metadata_json")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scenario     Scenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  avatar       Avatar       @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  recordings  Recording[]
  transcripts Transcript[]

  @@index([userId])
  @@index([orgId])
  @@index([status])
  @@index([startedAt])
  @@map("sessions")
}

enum SessionStatus {
  ACTIVE
  PROCESSING
  COMPLETED
  ERROR
}

model Recording {
  id            String        @id @default(uuid())
  sessionId     String        @map("session_id")
  type          RecordingType
  s3Url         String        @map("s3_url")
  cdnUrl        String?       @map("cdn_url")
  thumbnailUrl  String?       @map("thumbnail_url")
  fileSizeBytes BigInt        @map("file_size_bytes")
  createdAt     DateTime      @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("recordings")
}

enum RecordingType {
  USER
  AVATAR
  COMBINED
}

model Transcript {
  id             String     @id @default(uuid())
  sessionId      String     @map("session_id")
  speaker        Speaker
  text           String
  timestampStart Float      @map("timestamp_start")
  timestampEnd   Float      @map("timestamp_end")
  confidence     Float?
  highlight      Highlight?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([timestampStart])
  @@map("transcripts")
}

enum Speaker {
  AI
  USER
}

enum Highlight {
  POSITIVE
  NEGATIVE
  IMPORTANT
}
