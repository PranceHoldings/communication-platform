# Keep in .gitignore to prevent accidental re-creation
apps/web/i18n/
**/i18n/request.ts

# Old package.json backups
package.json.old
*.old

# Infrastructure temporary directories
infrastructure/apps/
infrastructure/*.broken-*

# Files with spaces (macOS Finder auto-generated copies)
# CRITICAL: Never create files/directories with spaces in names
*\ 2.*
*\ 2/
*\ [0-9].*
*\ [0-9]/
package-lock\ *.json
cdk\ *.out/
test-results/

# Any file or directory with space in name (comprehensive pattern)
# This catches all files/directories with spaces that aren't already ignored
*\ *.*
*\ */
*\ *\ *
