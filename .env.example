#############################################
# Environment Variables Template
#############################################
# IMPORTANT: このファイルをコピーして .env.local を作成してください
#
# 使い方:
# 1. このファイルを .env.local にコピー
#    cp .env.example .env.local
#
# 2. .env.local の xxxxx を実際のAPIキーに置き換え
#
# 3. .env.local は Git にコミットされません（.gitignore で保護）
#
# 詳細: docs/development/API_KEY_MANAGEMENT.md
#############################################

#############################################
# AWS Configuration
#############################################
# AWS_REGION: デフォルトリージョン（将来: スーパー管理者UIで変更可能）
# 注意: CloudFront証明書はus-east-1固定です
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

#############################################
# AWS Bedrock (Claude API)
#############################################
# Bedrockは AWS SDK が自動的にIAM認証を使用します。
# AWS認証情報（aws configure）が設定されていることを確認してください。
# 注意: BEDROCK_REGIONは将来スーパー管理者UIで変更可能になります
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

#############################################
# AWS Rekognition (感情解析) - 未実装
#############################################
# ⚠️ 将来機能: 感情解析機能未実装
# Rekognitionも AWS SDK が自動的にIAM認証を使用します。
# 注意: REKOGNITION_REGIONは将来スーパー管理者UIで変更可能になります
# REKOGNITION_REGION=us-east-1

#############################################
# AWS Polly (TTS フォールバック) - 未実装
#############################################
# ⚠️ 将来機能: 現在ElevenLabsのみ使用、Pollyフォールバックは未実装
# Pollyも AWS SDK が自動的にIAM認証を使用します。
# 注意: POLLY_REGIONは将来スーパー管理者UIで変更可能になります
# POLLY_REGION=us-east-1
# POLLY_VOICE_ID=Mizuki
# POLLY_ENGINE=neural

#############################################
# ElevenLabs (TTS プライマリ)
#############################################
# 品質優先のため、プライマリはElevenLabsを使用
# 注意: ELEVENLABS_MODEL_IDは将来スーパー管理者UIで変更可能になります
ELEVENLABS_API_KEY=xxxxx
ELEVENLABS_VOICE_ID=xxxxx
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

#############################################
# Azure Speech Services (STT)
#############################################
# 注意: AZURE_SPEECH_REGIONは将来スーパー管理者UIで変更可能になります
AZURE_SPEECH_KEY=xxxxx
AZURE_SPEECH_REGION=eastus

#############################################
# Ready Player Me - 未実装
#############################################
# ⚠️ 将来機能: アバター生成機能未実装
# READY_PLAYER_ME_APP_ID=xxxxx

#############################################
# Database
#############################################
# ⚠️ ローカルPostgreSQLは使用しません
# このプロジェクトはAWS RDS (Aurora Serverless v2)のみを使用します
DATABASE_URL=postgresql://user:password@host:5432/database

#############################################
# Authentication (JWT)
#############################################
# 本番環境では長く複雑なランダム文字列を使用してください
# 生成方法: openssl rand -base64 64
JWT_SECRET=dev-secret-change-in-production-use-long-random-string-at-least-32-characters
# ⚠️ 将来機能: トークン有効期限管理未実装（現在はSecret Managerで管理）
# JWT_ACCESS_TOKEN_EXPIRES_IN=24h
# JWT_REFRESH_TOKEN_EXPIRES_IN=30d

#############################################
# Next.js Frontend (NEXT_PUBLIC_* are exposed to browser)
#############################################
# REST API Base URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api  # 🔴 削除済み: NEXT_PUBLIC_API_URL と重複

# WebSocket Endpoint
# NEXT_PUBLIC_WS_URL=ws://localhost:3001  # 🔴 削除済み: NEXT_PUBLIC_WS_ENDPOINT と重複
NEXT_PUBLIC_WS_ENDPOINT=ws://localhost:3001

#############################################
# Sentry (Optional)
#############################################
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

#############################################
# Language and Media Configuration (Optional)
#############################################
# これらの設定は省略可能です。未設定の場合はデフォルト値が使用されます。
# 将来的にスーパー管理者UIで変更可能になります。

# STT言語設定（Azure Speech Services形式）
# デフォルト: en-US
# サポート: en-US, ja-JP, zh-CN, es-ES, fr-FR, de-DE, ko-KR
STT_LANGUAGE=en-US

# 動画フォーマット設定
# デフォルト: webm
VIDEO_FORMAT=webm

# 動画解像度設定
# デフォルト: 1280x720
VIDEO_RESOLUTION=1280x720

# 音声コンテンツタイプ
# デフォルト: audio/webm
AUDIO_CONTENT_TYPE=audio/webm

# 動画コンテンツタイプ
# デフォルト: video/webm
VIDEO_CONTENT_TYPE=video/webm

#############################################
# CloudFront Configuration (CDN)
#############################################
# CloudFrontドメイン（録画・アバター配信用）
CLOUDFRONT_DOMAIN=xxxxx.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=xxxxx
# CloudFrontプライベートキー（改行は\nで表現）
CLOUDFRONT_PRIVATE_KEY=xxxxx

#############################################
# Environment & Frontend Configuration
#############################################
# 環境識別子（dev, staging, production）
ENVIRONMENT=dev
# フロントエンドURL（CORS設定等で使用）
FRONTEND_URL=http://localhost:3000

#############################################
# Rate Limiting Configuration
#############################################
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_ATTEMPT_WINDOW=300
RATE_LIMIT_LOCKOUT_DURATION=900

#############################################
# Feature Flags
#############################################
# 自動解析を有効化（セッション完了時に自動的に解析を実行）
ENABLE_AUTO_ANALYSIS=true

#############################################
# STT Configuration (Optional - コメントアウト可)
#############################################
# STT言語設定（Azure Speech Services形式）
STT_LANGUAGE=en-US
# 自動言語検出を有効化（カンマ区切りで複数言語指定）
STT_AUTO_DETECT_LANGUAGES=en-US,ja-JP,zh-CN

#############################################
# AWS Lambda Environment Variables
#############################################
# ⚠️ 以下の変数はAWS CDKによってLambda関数に自動設定されます
# ローカル開発では不要ですが、検証スクリプトのために定義が必要
#
# Lambda関数名
AWS_LAMBDA_FUNCTION_NAME=prance-api-default-dev
# 解析Lambda関数名
ANALYSIS_LAMBDA_FUNCTION_NAME=prance-analysis-dev
# WebSocket接続テーブル
CONNECTIONS_TABLE_NAME=prance-websocket-connections-dev
# ゲストレート制限テーブル
GUEST_RATE_LIMIT_TABLE=prance-guest-rate-limit-dev
# S3バケット名
S3_BUCKET=prance-recordings-dev
# STORAGE_BUCKET_NAME=prance-recordings-dev  # 🔴 削除済み: S3_BUCKET と重複（2026-03-19統一）
# データベースクエリ用S3バケット
DB_QUERIES_BUCKET=prance-db-queries-dev
# WebSocketエンドポイント
WEBSOCKET_ENDPOINT=wss://xxxxx.execute-api.us-east-1.amazonaws.com/dev
# ffmpeg/ffprobeパス（Lambda Layer）
FFMPEG_PATH=/opt/bin/ffmpeg
FFPROBE_PATH=/opt/bin/ffprobe

#############################################
# Playwright Testing
#############################################
# E2Eテスト用ベースURL
BASE_URL=http://localhost:3000
