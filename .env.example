#############################################
# Environment Variables Template
#############################################
# IMPORTANT: このファイルをコピーして .env.local を作成してください
#
# 使い方:
# 1. このファイルを .env.local にコピー
#    cp .env.example .env.local
#
# 2. .env.local の xxxxx を実際のAPIキーに置き換え
#
# 3. .env.local は Git にコミットされません（.gitignore で保護）
#
# 詳細: docs/development/API_KEY_MANAGEMENT.md
#############################################

#############################################
# AWS Configuration
#############################################
# AWS_REGION: デフォルトリージョン（将来: スーパー管理者UIで変更可能）
# 注意: CloudFront証明書はus-east-1固定です
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

#############################################
# AWS Bedrock (Claude API)
#############################################
# Bedrockは AWS SDK が自動的にIAM認証を使用します。
# AWS認証情報（aws configure）が設定されていることを確認してください。
# 注意: BEDROCK_REGIONは将来スーパー管理者UIで変更可能になります
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

#############################################
# AWS Rekognition (感情解析)
#############################################
# Rekognitionも AWS SDK が自動的にIAM認証を使用します。
# 注意: REKOGNITION_REGIONは将来スーパー管理者UIで変更可能になります
REKOGNITION_REGION=us-east-1

#############################################
# AWS Polly (TTS フォールバック)
#############################################
# Pollyも AWS SDK が自動的にIAM認証を使用します。
# 注意: POLLY_REGIONは将来スーパー管理者UIで変更可能になります
POLLY_REGION=us-east-1
POLLY_VOICE_ID=Mizuki
POLLY_ENGINE=neural

#############################################
# ElevenLabs (TTS プライマリ)
#############################################
# 品質優先のため、プライマリはElevenLabsを使用
# 注意: ELEVENLABS_MODEL_IDは将来スーパー管理者UIで変更可能になります
ELEVENLABS_API_KEY=xxxxx
ELEVENLABS_VOICE_ID=xxxxx
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

#############################################
# Azure Speech Services (STT)
#############################################
# 注意: AZURE_SPEECH_REGIONは将来スーパー管理者UIで変更可能になります
AZURE_SPEECH_KEY=xxxxx
AZURE_SPEECH_REGION=eastus

#############################################
# Ready Player Me
#############################################
READY_PLAYER_ME_APP_ID=xxxxx

#############################################
# Database
#############################################
# ⚠️ ローカルPostgreSQLは使用しません
# このプロジェクトはAWS RDS (Aurora Serverless v2)のみを使用します
# DATABASE_URLはLambda関数の環境変数で自動設定されます
# DATABASE_URL=(AWS RDSで自動設定)

#############################################
# Authentication (JWT)
#############################################
# 本番環境では長く複雑なランダム文字列を使用してください
# 生成方法: openssl rand -base64 64
JWT_SECRET=dev-secret-change-in-production-use-long-random-string-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRES_IN=24h
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

#############################################
# Next.js
#############################################
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

#############################################
# Sentry (Optional)
#############################################
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
