#!/bin/bash
#
# Git Pre-Commit Hook
#
# ハードコード検出・環境変数整合性チェック・SSOT検証・ESLintを実行
# いずれかが失敗した場合、コミットをブロックする
#

# Load shared library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && cd ../../scripts && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

echo ""
print_separator "━" 54
log_info "🔍 Running pre-commit checks..."
print_separator "━" 54
echo ""

# Track overall status
CHECKS_FAILED=0

# Check 0: Schema-First Validation (CRITICAL - 2026-03-22)
echo -e "${YELLOW}[0/8]${NC} Validating Schema-First principle (CRITICAL)..."
if bash scripts/validate-schema-interface-implementation.sh > /dev/null 2>&1; then
  log_success "Schema-First validation passed"
else
  log_error "Schema-First validation failed"
  echo "Run: bash scripts/validate-schema-interface-implementation.sh"
  CHECKS_FAILED=1
fi

# Check 1: Hardcoded Values
echo -e "${YELLOW}[1/7]${NC} Checking for hardcoded values..."
if bash scripts/detect-hardcoded-values.sh > /dev/null 2>&1; then
  log_success "No hardcoded values detected"
else
  log_error "Hardcoded values detected"
  echo "Run: bash scripts/detect-hardcoded-values.sh"
  CHECKS_FAILED=1
fi

# Check 2: Environment Variables Consistency
echo -e "${YELLOW}[2/7]${NC} Validating environment variables consistency..."
if bash scripts/validate-env-consistency.sh > /dev/null 2>&1; then
  log_success "Environment variables are consistent"
else
  log_error "Environment variable inconsistency"
  echo "Run: bash scripts/validate-env-consistency.sh"
  CHECKS_FAILED=1
fi

# Check 3: Single Source of Truth (CRITICAL - 2026-03-20)
echo -e "${YELLOW}[3/7]${NC} Validating Single Source of Truth (.env.local)..."
if bash scripts/validate-env-single-source.sh > /dev/null 2>&1; then
  log_success "SSOT validation passed"
else
  log_error "SSOT validation failed"
  echo "Run: bash scripts/validate-env-single-source.sh"
  echo "Sync: bash scripts/sync-env-vars.sh"
  CHECKS_FAILED=1
fi

# Check 4: Duplication Management (CRITICAL - 2026-03-22)
echo -e "${YELLOW}[4/7]${NC} Validating duplication management..."
if bash scripts/validate-duplication.sh > /dev/null 2>&1; then
  log_success "Duplication validation passed"
else
  log_error "Duplication validation failed"
  echo "Run: bash scripts/validate-duplication.sh"
  CHECKS_FAILED=1
fi

# Check 5: ESLint on staged files
echo -e "${YELLOW}[5/7]${NC} Running ESLint on staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  if echo "$STAGED_FILES" | xargs npx eslint --max-warnings=0 > /dev/null 2>&1; then
    log_success "ESLint passed"
  else
    log_error "ESLint failed"
    CHECKS_FAILED=1
  fi
else
  log_success "No files to lint"
fi

# Check 6: TypeScript Type Check (if TS files changed)
echo -e "${YELLOW}[6/7]${NC} Running TypeScript type check..."
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS_FILES" ]; then
  if npm run type-check > /dev/null 2>&1; then
    log_success "TypeScript type check passed"
  else
    log_error "TypeScript type errors detected"
    echo "Run: npm run type-check"
    CHECKS_FAILED=1
  fi
else
  log_success "No TypeScript files to check"
fi

# Check 7: i18n Translation Keys Sync (CRITICAL - 2026-03-22)
echo -e "${YELLOW}[7/8]${NC} Validating i18n translation keys sync..."
STAGED_I18N_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'apps/web/messages/.*\.json$' || true)

if [ -n "$STAGED_I18N_FILES" ]; then
  if node scripts/validate-i18n-keys.js > /dev/null 2>&1; then
    log_success "All translation keys are synchronized"
  else
    log_error "Translation keys are not synchronized"
    echo "Run: cd apps/web && npm run i18n:validate"
    echo "Auto-fix: cd apps/web && npm run i18n:fix"
    CHECKS_FAILED=1
  fi
else
  log_success "No translation files modified"
fi

# Check 8: Shared Library Usage (CRITICAL - 2026-04-05)
echo -e "${YELLOW}[8/8]${NC} Validating shared library usage in scripts..."
STAGED_SCRIPT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'scripts/.*\.sh$' | grep -v 'archive/' | grep -v 'templates/' || true)
NEW_SCRIPT_FILES=$(git diff --cached --name-only --diff-filter=A | grep -E 'scripts/.*\.sh$' | grep -v 'archive/' | grep -v 'templates/' || true)

if [ -n "$STAGED_SCRIPT_FILES" ]; then
  # Comprehensive check for all staged scripts
  if bash scripts/validate-shared-lib-usage.sh > /dev/null 2>&1; then
    log_success "All scripts use shared library correctly"
  else
    log_error "Scripts not using shared library detected"
    echo "Run: bash scripts/validate-shared-lib-usage.sh"
    echo "Guide: scripts/CLAUDE.md - 共有ライブラリシステム"
    CHECKS_FAILED=1
  fi

  # Stricter validation for NEW scripts only
  if [ -n "$NEW_SCRIPT_FILES" ]; then
    echo ""
    log_info "🆕 Performing strict validation on new scripts..."
    NEW_SCRIPT_FAILED=0
    while IFS= read -r script; do
      if bash scripts/validate-new-script.sh "$script" > /dev/null 2>&1; then
        log_success "✓ $script"
      else
        log_error "✗ $script (strict validation failed)"
        echo "  Run: bash scripts/validate-new-script.sh $script"
        echo "  Tip: Use 'bash scripts/new-script.sh' to generate compliant scripts"
        NEW_SCRIPT_FAILED=1
      fi
    done <<< "$NEW_SCRIPT_FILES"

    if [ $NEW_SCRIPT_FAILED -eq 1 ]; then
      CHECKS_FAILED=1
    fi
  fi
else
  log_success "No script files modified"
fi

echo ""
print_separator "━" 54
if [ $CHECKS_FAILED -eq 0 ]; then
  log_success "All pre-commit checks passed"
  exit 0
else
  log_error "Pre-commit checks failed"
  echo "Fix the issues before committing."
  exit 1
fi
