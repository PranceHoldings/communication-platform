#!/bin/bash
#
# Git Pre-Commit Hook
#
# ハードコード検出・環境変数整合性チェック・SSOT検証・ESLintを実行
# いずれかが失敗した場合、コミットをブロックする
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}🔍 Running pre-commit checks...${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

# Track overall status
CHECKS_FAILED=0

# Check 0: Schema-First Validation (CRITICAL - 2026-03-22)
echo -e "${YELLOW}[0/7]${NC} Validating Schema-First principle (CRITICAL)..."
if bash scripts/validate-schema-interface-implementation.sh > /dev/null 2>&1; then
  echo -e "${GREEN}✅ Schema-First validation passed${NC}"
else
  echo -e "${RED}❌ Schema-First validation failed${NC}"
  echo "Run: bash scripts/validate-schema-interface-implementation.sh"
  CHECKS_FAILED=1
fi

# Check 1: Hardcoded Values
echo -e "${YELLOW}[1/7]${NC} Checking for hardcoded values..."
if bash scripts/detect-hardcoded-values.sh > /dev/null 2>&1; then
  echo -e "${GREEN}✅ No hardcoded values detected${NC}"
else
  echo -e "${RED}❌ Hardcoded values detected${NC}"
  echo "Run: bash scripts/detect-hardcoded-values.sh"
  CHECKS_FAILED=1
fi

# Check 2: Environment Variables Consistency
echo -e "${YELLOW}[2/7]${NC} Validating environment variables consistency..."
if bash scripts/validate-env-consistency.sh > /dev/null 2>&1; then
  echo -e "${GREEN}✅ Environment variables are consistent${NC}"
else
  echo -e "${RED}❌ Environment variable inconsistency${NC}"
  echo "Run: bash scripts/validate-env-consistency.sh"
  CHECKS_FAILED=1
fi

# Check 3: Single Source of Truth (CRITICAL - 2026-03-20)
echo -e "${YELLOW}[3/7]${NC} Validating Single Source of Truth (.env.local)..."
if bash scripts/validate-env-single-source.sh > /dev/null 2>&1; then
  echo -e "${GREEN}✅ SSOT validation passed${NC}"
else
  echo -e "${RED}❌ SSOT validation failed${NC}"
  echo "Run: bash scripts/validate-env-single-source.sh"
  echo "Sync: bash scripts/sync-env-vars.sh"
  CHECKS_FAILED=1
fi

# Check 4: Duplication Management (CRITICAL - 2026-03-22)
echo -e "${YELLOW}[4/7]${NC} Validating duplication management..."
if bash scripts/validate-duplication.sh > /dev/null 2>&1; then
  echo -e "${GREEN}✅ Duplication validation passed${NC}"
else
  echo -e "${RED}❌ Duplication validation failed${NC}"
  echo "Run: bash scripts/validate-duplication.sh"
  CHECKS_FAILED=1
fi

# Check 5: ESLint on staged files
echo -e "${YELLOW}[5/7]${NC} Running ESLint on staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  if echo "$STAGED_FILES" | xargs npx eslint --max-warnings=0 > /dev/null 2>&1; then
    echo -e "${GREEN}✅ ESLint passed${NC}"
  else
    echo -e "${RED}❌ ESLint failed${NC}"
    CHECKS_FAILED=1
  fi
else
  echo -e "${GREEN}✅ No files to lint${NC}"
fi

# Check 6: TypeScript Type Check (if TS files changed)
echo -e "${YELLOW}[6/7]${NC} Running TypeScript type check..."
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS_FILES" ]; then
  if npm run type-check > /dev/null 2>&1; then
    echo -e "${GREEN}✅ TypeScript type check passed${NC}"
  else
    echo -e "${RED}❌ TypeScript type errors detected${NC}"
    echo "Run: npm run type-check"
    CHECKS_FAILED=1
  fi
else
  echo -e "${GREEN}✅ No TypeScript files to check${NC}"
fi

# Check 7: i18n Translation Keys Sync (CRITICAL - 2026-03-22)
echo -e "${YELLOW}[7/7]${NC} Validating i18n translation keys sync..."
STAGED_I18N_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'apps/web/messages/.*\.json$' || true)

if [ -n "$STAGED_I18N_FILES" ]; then
  if node scripts/validate-i18n-keys.js > /dev/null 2>&1; then
    echo -e "${GREEN}✅ All translation keys are synchronized${NC}"
  else
    echo -e "${RED}❌ Translation keys are not synchronized${NC}"
    echo "Run: cd apps/web && npm run i18n:validate"
    echo "Auto-fix: cd apps/web && npm run i18n:fix"
    CHECKS_FAILED=1
  fi
else
  echo -e "${GREEN}✅ No translation files modified${NC}"
fi

echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
if [ $CHECKS_FAILED -eq 0 ]; then
  echo -e "${GREEN}✅ All pre-commit checks passed${NC}"
  exit 0
else
  echo -e "${RED}❌ Pre-commit checks failed${NC}"
  echo "Fix the issues before committing."
  exit 1
fi
