      ],
      "dependencies": [],
      "lastUpdated": "2026-04-04"
    },
    {
      "name": "aws.sh",
      "path": "scripts/lib/aws.sh",
      "description": "AWS CLI wrappers with retry logic",
      "exports": [
        "Lambda: invoke_lambda, get_lambda_config, list_lambda_functions, lambda_function_exists",
        "S3: s3_upload, s3_download, s3_delete, s3_object_exists, s3_list",
        "API Gateway: get_rest_api_id, get_websocket_api_id, test_api_endpoint",
