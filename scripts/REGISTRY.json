        "Counters: PASSED, FAILED, ERRORS, WARNINGS, SKIPPED",
        "Logging: log_success, log_error, log_warning, log_info, log_step, log_section, log_debug, log_retry",
        "Error handling: die, require_command, require_file, require_directory, require_env",
