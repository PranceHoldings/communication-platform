{
  "name": "prance-communication-platform",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "AI Avatar Communication Platform - Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infrastructure"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "clean": "turbo run clean && rm -rf node_modules",
    "setup:dev": "npm install && npm run db:generate",
    "db:generate": "cd packages/database && npx prisma generate",
    "cdk:bootstrap": "cd infrastructure && npx cdk bootstrap",
    "cdk:deploy": "cd infrastructure && npx cdk deploy --all",
    "cdk:destroy": "cd infrastructure && npx cdk destroy --all",
    "deploy:staging": "npm run build && npm run cdk:deploy -- -c environment=staging",
    "deploy:production": "npm run build && npm run cdk:deploy -- -c environment=production"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.2.4",
    "turbo": "^1.12.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
