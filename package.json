{
  "name": "prance-communication-platform",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "AI Avatar Communication Platform - Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infrastructure"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "prebuild": "mkdir -p packages/database/node_modules && cp -r node_modules/@prisma packages/database/node_modules/ 2>/dev/null || true && npm run db:generate",
    "build": "turbo run build",
    "build:clean": "bash scripts/clean-build.sh",
    "test": "turbo run test",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:broken": "bash scripts/cleanup-broken-files.sh",
    "setup:dev": "npm install && npm run db:generate",
    "db:generate": "cd packages/database && npx prisma generate",
    "cdk:bootstrap": "cd infrastructure && npx cdk bootstrap",
    "cdk:deploy": "cd infrastructure && npx cdk deploy --all",
    "cdk:destroy": "cd infrastructure && npx cdk destroy --all",
    "deploy:check": "bash scripts/pre-deploy-check.sh",
    "deploy:simple": "cd infrastructure && ./deploy-simple.sh dev",
    "deploy:dev": "cd infrastructure && ./deploy.sh dev",
    "deploy:dev:skip-build": "cd infrastructure && ./deploy.sh dev --skip-build",
    "deploy:dev:clean": "cd infrastructure && ./clean-deploy.sh dev",
    "deploy:staging": "cd infrastructure && ./deploy.sh staging",
    "deploy:staging:skip-build": "cd infrastructure && ./deploy.sh staging --skip-build",
    "deploy:production": "cd infrastructure && ./deploy.sh production",
    "consistency:check": "bash scripts/detect-inconsistencies.sh",
    "consistency:fix": "bash scripts/fix-inconsistencies.sh",
    "consistency:validate": "ts-node scripts/validate-consistency.ts",
    "pre-commit": "npm run consistency:validate && npm run lint && npm run typecheck",
    "env:validate": "bash scripts/validate-env.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.2.4",
    "turbo": "^1.12.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "ws": "^8.19.0"
  }
}
