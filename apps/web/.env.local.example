# Next.js Application Environment Variables

# API URL
NEXT_PUBLIC_API_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/dev/api/v1

# WebSocket URL (AWS API Gateway WebSocket)
NEXT_PUBLIC_WS_ENDPOINT=wss://your-websocket-url.execute-api.us-east-1.amazonaws.com/dev

# App Configuration
NEXT_PUBLIC_APP_NAME=Prance Communication Platform
NEXT_PUBLIC_APP_VERSION=0.1.0-alpha

# Default Locale
NEXT_PUBLIC_DEFAULT_LOCALE=ja

# Feature Flags
NEXT_PUBLIC_ENABLE_3D_AVATARS=true
NEXT_PUBLIC_ENABLE_VOICE_CLONING=false

# Environment
NODE_ENV=development
