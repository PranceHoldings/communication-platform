{
  "name": "@prance/web",
  "version": "0.1.0-alpha",
  "private": true,
  "scripts": {
    "dev": "PORT=3000 next dev",
    "dev:clean": "bash scripts/dev-clean.sh",
    "dev:restart": "bash scripts/dev-restart.sh",
    "dev:ws": "node scripts/mock-websocket-server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ws\"",
    "prebuild": "bash ../../scripts/validate-i18n-keys.sh",
    "build": "next build",
    "start": "PORT=3000 next start",
    "start:clean": "bash scripts/start-clean.sh",
    "lint": "next lint",
    "clean": "rm -rf .next",
    "kill-port": "bash scripts/kill-port.sh",
    "i18n:validate": "bash ../../scripts/validate-i18n-keys.sh",
    "i18n:fix": "bash ../../scripts/validate-i18n-keys.sh --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:stage1": "playwright test tests/e2e/stage1",
    "test:e2e:stage2": "playwright test tests/e2e/stage2",
    "test:e2e:stage3": "playwright test tests/e2e/stage3",
    "test:e2e:cors": "playwright test tests/e2e/cors-check.spec.ts",
    "test:e2e:health": "playwright test tests/e2e/deployment-health.spec.ts",
    "test:e2e:smoke": "playwright test tests/e2e/deployment-health.spec.ts tests/e2e/cors-check.spec.ts",
    "test:e2e:report": "playwright show-report test-results/html"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prance/database": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.96.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.0.0",
    "lucide-react": "^1.7.0",
    "next": "^15.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@prance/shared": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.160.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "ws": "^8.19.0"
  }
}
